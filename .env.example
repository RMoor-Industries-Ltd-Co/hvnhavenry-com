# ─── HVN Havenry Environment Variables ───────────────────────────────────────
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local — it is gitignored.

# Shopify Storefront API (optional — only needed if embedding cart/checkout)
# Get from: Shopify Admin → Settings → Apps → Develop apps → Storefront API
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=hvnhavenry.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# If using Shopify Buy Button (JS SDK) the token above is the one needed.
# Leave blank to use direct product page links instead (default mode).
